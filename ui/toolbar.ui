<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name toolbar.ui -->
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkToolbar" id="main_toolbar">
    <property name="visible">True</property>
    <child>
      <object class="GtkToolButton" id="new_button">
        <property name="icon-name">document-new</property>
        <property name="label">New</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object class="GtkToolButton" id="open_button">
        <property name="icon-name">document-open</property>
        <property name="label">Open</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object class="GtkSeparatorToolItem" id="sep1">
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object class="GtkToolButton" id="quit_button">
        <property name="icon-name">application-exit</property>
        <property name="label">Quit</property>
        <property name="visible">True</property>
      </object>
    </child>
  </object>
</interface>
